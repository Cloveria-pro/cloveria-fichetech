      "tempsPreparation": 20,
      "tempsCuisson": 25,
      "allergenes": ["lait"],
      "description": "Magret de canard poêlé peau croustillante, nappé d'une sauce au vin rouge montée au beurre. Finition thym et fleur de sel.",
      "ingredients": [
        { "nom": "Magret de canard",    "quantite": 0.9, "unite": "kg",    "prixUnitaire": 18.50 },
