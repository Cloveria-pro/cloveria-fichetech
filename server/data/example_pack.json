    {
      "id": "ex-sr-01",
      "user_id": "__example__",
      "nom": "Sauce au vin rouge",
      "portions": 4,
      "ingredients": [
        { "nom": "Vin rouge",    "quantite": 0.5,   "unite": "L"     },
        { "nom": "Fond de veau", "quantite": 0.25,  "unite": "L"     },
        { "nom": "Échalotes",   "quantite": 0.06,  "unite": "kg"    },
        { "nom": "Beurre doux", "quantite": 0.04,  "unite": "kg"    },
        { "nom": "Thym frais",  "quantite": 0.005, "unite": "kg"    }
      ],
      "etapes": [
        "Ciseler finement les échalotes.",
        "Dans une sauteuse, faire revenir les échalotes dans la moitié du beurre à feu doux jusqu'à transparence (3 min).",
        "Déglacer avec le vin rouge, ajouter le thym, réduire de 2/3 à feu moyen.",
        "Ajouter le fond de veau, réduire jusqu'à consistance nappante (8-10 min).",
        "Hors du feu, monter au beurre restant en fouettant. Rectifier l'assaisonnement. Passer au chinois fin."
      ],
      "createdAt": "2026-05-24T00:00:00.000Z",
      "updatedAt": "2026-05-24T00:00:00.000Z"
    },
    {
      "id": "ex-sr-02",
      "user_id": "__example__",
      "nom": "Pâte sablée",
      "portions": 6,
      "ingredients": [
        { "nom": "Farine T55",  "quantite": 0.25,  "unite": "kg"    },
        { "nom": "Beurre doux", "quantite": 0.125, "unite": "kg"    },
        { "nom": "Sucre",       "quantite": 0.08,  "unite": "kg"    },
        { "nom": "Oeufs frais", "quantite": 1,     "unite": "piece" }
      ],
      "etapes": [
        "Sortir le beurre 30 min à l'avance pour le ramollir à température ambiante.",
        "Mélanger beurre pommade et sucre jusqu'à obtenir une texture crémeuse.",
        "Incorporer l'œuf entier, mélanger brièvement.",
        "Ajouter la farine d'un coup, sabler du bout des doigts sans trop travailler la pâte.",
        "Former une boule, filmer et réfrigérer 1 h minimum avant utilisation."
      ],
